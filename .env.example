# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=datasentinel
POSTGRES_PASSWORD=datasentinel
POSTGRES_DB=datasentinel

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── OpenMetadata (pipeline agent lineage) ────────────────────────────────────
OPENMETADATA_HOST=http://localhost:8585
OPENMETADATA_TOKEN=

# ── Module tuning ─────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
SEMANTIC_BATCH_SIZE=50
MAX_FIX_ITERATIONS=3
